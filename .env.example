# Example .env file for Karaoke Lyrics Generation Pipeline
# Copy this file to `.env` and adjust values as needed.

# Path to the directory containing audio and lyric files
MEDIA_DIR=./media/songs

# Set to true to fetch lyrics from the internet (lrclib.net)
FETCH_FROM_WEB=true

# Set to true to generate unsynced lyrics with WhisperX if .txt is missing
GENERATE_UNSYNCED_LYRICS=true

# Set to true to generate LRC file from JSON
GENERATE_SYNCED_LYRICS=true

# Set to true to generate ASS karaoke file from JSON
GENERATE_KARAOKE_LYRICS=true

# Set to true to add lyrics tags to audio files (if supported)
ADD_LYRICS_TAGS=true

# Set the language for WhisperX transcription (e.g., es for Spanish, en for English, fr for French)
#WHISPERX_LANGUAGE=es